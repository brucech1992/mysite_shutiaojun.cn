---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import EngagementPanel from '../components/EngagementPanel.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PostStats from '../components/PostStats.astro';
import SiteSidebar from '../components/SiteSidebar.astro';
import { getColumnMeta } from '../lib/columns';

interface TagItem {
	name: string;
	count: number;
	href: string;
	sizeLevel: 1 | 2 | 3;
}

interface PopularPost {
	id: string;
	title: string;
	column: CollectionEntry<'blog'>['data']['column'];
}

type Props = CollectionEntry<'blog'>['data'] & {
	postId: string;
	tags: TagItem[];
	routeMap: Record<string, string>;
	popularPosts: PopularPost[];
};

const { title, description, pubDate, updatedDate, heroImage, postId, column, resources, tags, routeMap, popularPosts } =
	Astro.props;
const columnMeta = getColumnMeta(column);
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(var(--site-width), calc(100% - 2rem));
				max-width: none;
				margin: 0 auto;
				padding: 1.1rem 0 2.8rem;
			}
			.article-layout {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 300px;
				gap: 1.4rem;
			}
			.article-shell {
				border: 0;
				padding: 0;
				background: transparent;
			}
			.hero-image {
				padding-bottom: 0.9rem;
				border-bottom: 1px solid rgba(103, 117, 128, 0.45);
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 0;
			}
			.prose {
				width: min(760px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1.2rem 0 1rem;
				font-size: 18px;
				line-height: 1.92;
				letter-spacing: 0.01em;
				color: #2e3a45;
			}
			.title {
				margin-bottom: 1.1rem;
				padding-bottom: 0.95rem;
				border-bottom: 1px solid #e5eaee;
			}
			.title h1 {
				margin: 0.1rem 0 0.75rem;
				font-size: clamp(1.95rem, 4vw, 2.45rem);
				line-height: 1.35;
				font-weight: 600;
				color: #2f3b45;
			}
			.date {
				margin-bottom: 0.2rem;
				font-size: 0.85rem;
				letter-spacing: 0.03em;
				color: #75818b;
			}
			.last-updated-on {
				font-size: 0.83rem;
			}
			.prose :global(p) {
				margin: 0 0 1.45rem;
				line-height: 1.92;
			}
			.prose :global(h2) {
				margin: 2.2rem 0 0.95rem;
				font-size: 1.42rem;
				line-height: 1.5;
				font-family: var(--font-heading);
			}
			.prose :global(h3) {
				margin: 1.7rem 0 0.75rem;
				font-size: 1.16rem;
				line-height: 1.55;
			}
			.prose :global(ul),
			.prose :global(ol) {
				margin: 0.6rem 0 1.4rem 1.25rem;
			}
			.resources {
				margin-top: 2rem;
				padding: 1rem 0 0;
				border-top: 1px solid rgba(103, 117, 128, 0.45);
			}
			.resources h3 {
				margin: 0 0 0.55rem;
				font-size: 1.02rem;
			}
			.resources ul {
				margin: 0;
				padding-left: 1.05rem;
				display: grid;
				gap: 0.45rem;
			}
			.resources a {
				color: #3d5263;
			}
			.article-sidebar {
				display: grid;
				gap: 0.95rem;
				align-content: start;
			}
			.popular-widget {
				padding: 0 0 0.95rem;
			}
			.popular-widget h3 {
				margin: 0 0 0.8rem;
				font-size: 1rem;
				letter-spacing: 0.03em;
				font-family: var(--font-heading);
				color: #3a4651;
			}
			.popular-widget ol {
				margin: 0;
				padding-left: 1.1rem;
				display: grid;
				gap: 0.55rem;
			}
			.popular-widget a {
				color: #41586a;
				text-decoration: none;
				font-size: 0.88rem;
				line-height: 1.6;
			}
			.popular-widget a:hover {
				color: #1e2c38;
				text-decoration: underline;
			}
			.popular-meta {
				display: block;
				font-size: 0.76rem;
				color: #7a8790;
				margin-top: 0.1rem;
			}
			.empty-popular {
				margin: 0;
				font-size: 0.86rem;
				color: #76848f;
			}
			.article-sidebar > :global(.site-sidebar) {
				border-top: 1px solid rgba(103, 117, 128, 0.45);
				padding-top: 0.95rem;
			}
			@media (max-width: 980px) {
				.article-layout {
					grid-template-columns: 1fr;
				}
				.article-sidebar {
					order: 2;
				}
			}
			@media (max-width: 720px) {
				main {
					width: calc(100% - 1.2rem);
				}
				.prose {
					font-size: 17px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<section class="article-layout">
				<article class="article-shell">
					<div class="hero-image">
						{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
					</div>
					<div class="prose">
						<div class="title">
							<h1>{title}</h1>
							<div class="date">
								发表于 <FormattedDate date={pubDate} /> · {columnMeta.name}
								{
									updatedDate && (
										<div class="last-updated-on">
											最后更新于 <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
						</div>
						<PostStats postId={postId} />
						<slot />
						{resources && resources.length > 0 && (
							<section class="resources">
								<h3>延伸阅读 / 相关链接</h3>
								<ul>
									{resources.map((item) => (
										<li>
											<a href={item.url} target="_blank" rel="noreferrer">{item.title}</a>
											{item.note && <span> · {item.note}</span>}
										</li>
									))}
								</ul>
							</section>
						)}
						<EngagementPanel postId={postId} />
					</div>
				</article>

				<div class="article-sidebar">
					<section class="popular-widget">
						<h3>热门文章</h3>
						{
							popularPosts.length > 0 ? (
								<ol>
									{popularPosts.map((item) => (
										<li>
											<a href={`/${item.column}/${item.id}/`}>{item.title}</a>
											<span class="popular-meta">{getColumnMeta(item.column).name}</span>
										</li>
									))}
								</ol>
							) : (
								<p class="empty-popular">暂无可展示内容</p>
							)
						}
					</section>
					<SiteSidebar tags={tags} routeMap={routeMap} />
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
