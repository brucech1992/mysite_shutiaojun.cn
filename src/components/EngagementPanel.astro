---
interface Props {
	postId: string;
}

const { postId } = Astro.props;
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<section
	class="engagement"
	data-post-id={postId}
	data-supabase-url={supabaseUrl}
	data-supabase-key={supabaseAnonKey}
>
	<h3>点赞与评论</h3>
	<p class="hint">发表评论前请登记用户名与联系邮箱。</p>
	<p class="hint muted backend-status">正在连接云端互动服务...</p>

	<form class="profile-form">
		<label>
			用户名
			<input class="profile-name" type="text" placeholder="请输入用户名" required />
		</label>
		<label>
			联系邮箱
			<input class="profile-email" type="email" placeholder="请输入邮箱" required />
		</label>
		<button type="submit">登记/更新资料</button>
		<p class="profile-status" aria-live="polite"></p>
	</form>

	<div class="like-row">
		<button type="button" class="like-btn">点赞</button>
		<span class="like-count">0 个赞</span>
	</div>

	<form class="comment-form">
		<label>
			评论内容
			<textarea class="comment-input" rows="4" placeholder="写下你的想法..." required></textarea>
		</label>
		<button type="submit">发布评论</button>
		<p class="comment-status" aria-live="polite"></p>
	</form>

	<div class="comment-list"></div>
</section>

<style>
	.engagement {
		margin-top: 2.5rem;
		border: 1px solid #d8e6ef;
		border-radius: 12px;
		background: #f6fbff;
		padding: 1rem;
	}
	.engagement h3 {
		margin: 0 0 0.4rem;
		font-size: 1.2rem;
	}
	.hint {
		margin: 0.2rem 0;
		font-size: 0.9rem;
		color: #5e6a73;
	}
	.muted {
		font-size: 0.82rem;
		color: #7e8a93;
	}
	.profile-form,
	.comment-form {
		display: grid;
		gap: 0.5rem;
		margin-top: 0.8rem;
	}
	label {
		display: grid;
		gap: 0.2rem;
		font-size: 0.9rem;
		color: #334455;
	}
	input,
	textarea {
		border: 1px solid #bdd3e0;
		border-radius: 8px;
		padding: 0.55rem 0.65rem;
		font: inherit;
		background: #fff;
		color: #24323e;
	}
	button {
		width: fit-content;
		border: 1px solid #7aa3be;
		border-radius: 999px;
		padding: 0.42rem 0.9rem;
		background: #eaf5fc;
		color: #2b4558;
		font-size: 0.9rem;
		cursor: pointer;
	}
	button:hover {
		background: #deeff9;
	}
	button:disabled {
		cursor: not-allowed;
		opacity: 0.6;
	}
	.profile-status,
	.comment-status {
		margin: 0;
		min-height: 1.2rem;
		font-size: 0.85rem;
		color: #50616f;
	}
	.like-row {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		margin-top: 0.9rem;
	}
	.like-count {
		font-size: 0.9rem;
		color: #50616f;
	}
	.comment-list {
		display: grid;
		gap: 0.65rem;
		margin-top: 1rem;
	}
	.comment-item {
		border: 1px solid #d7e3eb;
		border-radius: 10px;
		background: #fff;
		padding: 0.7rem;
	}
	.comment-meta {
		font-size: 0.82rem;
		color: #6a7782;
		margin-bottom: 0.35rem;
	}
	.comment-body {
		margin: 0;
		font-size: 0.92rem;
		color: #2f3d49;
		white-space: pre-wrap;
		word-break: break-word;
	}
</style>

<script is:inline>
(() => {
	const PROFILE_KEY = 'sj_profile_v1';

	const parseJson = (value) => {
		if (!value) return {};
		try {
			return JSON.parse(value);
		} catch {
			return {};
		}
	};

	const maskEmail = (email) => {
		if (!email || !email.includes('@')) return '***';
		const [local, domain] = email.split('@');
		if (!local || !domain) return '***';
		const first = local[0] || '*';
		const domainParts = domain.split('.');
		if (domainParts.length < 2) {
			return `${first}***@${domain}`;
		}
		const domainHead = domainParts[0];
		const suffix = domainParts.slice(1).join('.');
		const maskedDomainHead = domainHead.length > 2 ? `${domainHead.slice(0, 2)}***` : `${domainHead[0]}***`;
		return `${first}***@${maskedDomainHead}.${suffix}`;
	};

	const loadProfile = () => parseJson(localStorage.getItem(PROFILE_KEY));
	const saveProfile = (profile) => localStorage.setItem(PROFILE_KEY, JSON.stringify(profile));

	document.querySelectorAll('.engagement[data-post-id]').forEach((root) => {
		const postId = root.getAttribute('data-post-id') || 'default';
		const supabaseUrl = (root.getAttribute('data-supabase-url') || '').replace(/\/$/, '');
		const supabaseKey = root.getAttribute('data-supabase-key') || '';
		const backendStatus = root.querySelector('.backend-status');
		const profileForm = root.querySelector('.profile-form');
		const nameInput = root.querySelector('.profile-name');
		const emailInput = root.querySelector('.profile-email');
		const profileStatus = root.querySelector('.profile-status');
		const likeBtn = root.querySelector('.like-btn');
		const likeCount = root.querySelector('.like-count');
		const commentForm = root.querySelector('.comment-form');
		const commentInput = root.querySelector('.comment-input');
		const commentStatus = root.querySelector('.comment-status');
		const commentList = root.querySelector('.comment-list');

		const isConfigured = Boolean(supabaseUrl && supabaseKey);

		const request = async (path, { method = 'GET', body, prefer } = {}) => {
			const headers = {
				apikey: supabaseKey,
				Authorization: `Bearer ${supabaseKey}`,
			};

			if (method !== 'GET') {
				headers['Content-Type'] = 'application/json';
			}
			if (prefer) {
				headers['Prefer'] = prefer;
			}

			const response = await fetch(`${supabaseUrl}/rest/v1/${path}`, {
				method,
				headers,
				body: body ? JSON.stringify(body) : undefined,
			});

			if (!response.ok) {
				const detail = await response.text();
				const error = new Error(detail || `HTTP ${response.status}`);
				error.status = response.status;
				throw error;
			}

			const contentType = response.headers.get('content-type') || '';
			if (contentType.includes('application/json')) {
				return response.json();
			}
			return [];
		};

		const renderProfile = () => {
			const profile = loadProfile();
			nameInput.value = profile.username || '';
			emailInput.value = profile.email || '';
		};

		const renderComments = (comments) => {
			commentList.innerHTML = '';

			if (!comments.length) {
				const empty = document.createElement('p');
				empty.className = 'hint';
				empty.textContent = '还没有评论，来发布第一条吧。';
				commentList.appendChild(empty);
				return;
			}

			comments.forEach((item) => {
				const card = document.createElement('article');
				card.className = 'comment-item';

				const meta = document.createElement('p');
				meta.className = 'comment-meta';
				meta.textContent = `${item.username} · ${maskEmail(item.email)} · ${new Date(item.created_at).toLocaleString()}`;

				const body = document.createElement('p');
				body.className = 'comment-body';
				body.textContent = item.content;

				card.append(meta, body);
				commentList.appendChild(card);
			});
		};

		const refreshRemoteData = async () => {
			const postKey = encodeURIComponent(postId);
			const [likes, comments] = await Promise.all([
				request(`post_likes?post_id=eq.${postKey}&select=id`),
				request(
					`post_comments?post_id=eq.${postKey}&select=username,email,content,created_at&order=created_at.desc`,
				),
			]);
			likeCount.textContent = `${likes.length} 个赞`;
			renderComments(comments);
		};

		renderProfile();

		if (!isConfigured) {
			backendStatus.textContent =
				'互动云端未配置（缺少 PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY），暂不可用。';
			likeBtn.disabled = true;
			commentInput.disabled = true;
			commentForm.querySelector('button').disabled = true;
			profileForm.querySelector('button').disabled = true;
			return;
		}

		backendStatus.textContent = '互动数据将保存到云端。';

		refreshRemoteData().catch(() => {
			backendStatus.textContent = '云端连接失败，请稍后刷新重试。';
		});

		profileForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			const username = nameInput.value.trim();
			const email = emailInput.value.trim();

			if (!username || !email) {
				profileStatus.textContent = '请完整填写用户名和邮箱。';
				return;
			}

			saveProfile({ username, email });
			profileStatus.textContent = '资料保存中...';

			try {
				await request('visitor_profiles', {
					method: 'POST',
					body: [{ email, username }],
					prefer: 'resolution=merge-duplicates,return=minimal',
				});
				profileStatus.textContent = '资料已保存，可以点赞和评论了。';
			} catch {
				profileStatus.textContent = '资料已保存到本地，但云端同步失败。';
			}
		});

		likeBtn.addEventListener('click', async () => {
			const profile = loadProfile();
			if (!profile.username || !profile.email) {
				profileStatus.textContent = '请先登记用户名和邮箱后再点赞。';
				return;
			}

			commentStatus.textContent = '正在点赞...';
			try {
				await request('post_likes', {
					method: 'POST',
					body: [{ post_id: postId, email: profile.email }],
					prefer: 'return=minimal',
				});
				commentStatus.textContent = '点赞成功。';
				await refreshRemoteData();
			} catch (error) {
				if (error.status === 409 || String(error.message).includes('duplicate key')) {
					commentStatus.textContent = '你已经点过赞了。';
					return;
				}
				commentStatus.textContent = '点赞失败，请稍后重试。';
			}
		});

		commentForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			const profile = loadProfile();
			const content = commentInput.value.trim();

			if (!profile.username || !profile.email) {
				commentStatus.textContent = '请先登记用户名和邮箱后再评论。';
				return;
			}

			if (!content) {
				commentStatus.textContent = '评论内容不能为空。';
				return;
			}

			commentStatus.textContent = '正在发布评论...';
			try {
				await request('post_comments', {
					method: 'POST',
					body: [{
						post_id: postId,
						email: profile.email,
						username: profile.username,
						content,
					}],
					prefer: 'return=minimal',
				});
				commentInput.value = '';
				commentStatus.textContent = '评论已发布。';
				await refreshRemoteData();
			} catch {
				commentStatus.textContent = '评论发布失败，请稍后重试。';
			}
		});
	});
})();
</script>
