---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/about">关于我</HeaderLink>
			<HeaderLink href="/projects">项目</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/#contact">联系我</HeaderLink>
		</div>
		<a class="talk-btn" href="/#contact">一起聊聊</a>
	</nav>
</header>
<style>
	header { margin: 0; padding: 0 1em; background: white; box-shadow: 0 2px 8px rgba(var(--black), 5%); }
	h2 { margin: 0; font-size: 1em; }
	h2 a, h2 a.active { text-decoration: none; }
	nav { display: flex; align-items: center; justify-content: space-between; gap: 1rem; min-height: 72px; }
	.internal-links { display: flex; flex-wrap: wrap; }
	nav a { padding: 1em 0.5em; color: var(--black); border-bottom: 4px solid transparent; text-decoration: none; }
	nav a.active { text-decoration: none; border-bottom-color: var(--accent); }
	.talk-btn { padding: 0.6em 1em; border-radius: 12px; border: none; color: #fff; background: var(--accent); font-weight: 700; }
	@media (max-width: 900px) { nav { flex-wrap: wrap; padding: 0.5rem 0; } .talk-btn { margin-left: auto; } }
</style>
