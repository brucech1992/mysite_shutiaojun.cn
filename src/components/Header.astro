---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav class="top-links" aria-label="主导航">
		<HeaderLink href="/yuanwei">原味薯条</HeaderLink>
		<HeaderLink href="/fanqiejiang">蕃茄酱</HeaderLink>
		<HeaderLink href="/haiou-kanguo">海鸥看过</HeaderLink>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid #eceff2;
		background: #ffffff;
	}
	.top-links {
		width: min(var(--site-width), calc(100% - 2rem));
		margin: 0 auto;
		padding: 0.55rem 0;
		display: flex;
		justify-content: center;
		gap: 1.2rem;
		flex-wrap: wrap;
	}
	.top-links a {
		padding: 0.3rem 0;
		font-size: 0.9rem;
		text-decoration: none;
		letter-spacing: 0.03em;
		color: #5a6672;
		border-bottom: 1px solid transparent;
	}
	.top-links a:hover,
	.top-links a.active {
		color: #1f2a35;
		border-bottom-color: #9ea8b1;
	}
</style>
