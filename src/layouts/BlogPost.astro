---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import EngagementPanel from '../components/EngagementPanel.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import PostStats from '../components/PostStats.astro';
import { getColumnMeta } from '../lib/columns';

type Props = CollectionEntry<'blog'>['data'] & { postId: string };

const { title, description, pubDate, updatedDate, heroImage, postId, column, resources } = Astro.props;
const columnMeta = getColumnMeta(column);
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(980px, calc(100% - 2rem));
				max-width: none;
				margin: 0 auto;
				padding: 1.3rem 0 2.8rem;
			}
			.article-shell {
				background: #ffffff;
				border: 1px solid #e4e8ec;
				padding: 0.9rem;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 0;
			}
			.prose {
				width: min(760px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1.2rem 0 1rem;
				font-size: 18px;
				line-height: 1.92;
				letter-spacing: 0.01em;
				color: #2e3a45;
			}
			.title {
				margin-bottom: 1.1rem;
				padding-bottom: 0.95rem;
				border-bottom: 1px solid #e5eaee;
			}
			.pill {
				display: inline-flex;
				align-items: center;
				font-size: 0.82rem;
				padding: 0.22rem 0.6rem;
				border: 1px solid #d7dfe5;
				color: #4b5c68;
				text-decoration: none;
				margin-bottom: 0.72rem;
			}
			.title h1 {
				margin: 0.2rem 0 0.75rem;
				font-size: clamp(1.95rem, 4vw, 2.45rem);
				line-height: 1.35;
				font-weight: 600;
				color: #2f3b45;
			}
			.date {
				margin-bottom: 0.2rem;
				font-size: 0.85rem;
				letter-spacing: 0.03em;
				color: #75818b;
			}
			.last-updated-on {
				font-size: 0.83rem;
			}
			.prose :global(p) {
				margin: 0 0 1.45rem;
				line-height: 1.92;
			}
			.prose :global(h2) {
				margin: 2.2rem 0 0.95rem;
				font-size: 1.42rem;
				line-height: 1.5;
				font-family: var(--font-heading);
			}
			.prose :global(h3) {
				margin: 1.7rem 0 0.75rem;
				font-size: 1.16rem;
				line-height: 1.55;
			}
			.prose :global(ul),
			.prose :global(ol) {
				margin: 0.6rem 0 1.4rem 1.25rem;
			}
			.resources {
				margin-top: 2rem;
				padding: 1rem;
				border: 1px solid #e4e9ee;
				background: #fbfcfd;
			}
			.resources h3 {
				margin: 0 0 0.55rem;
				font-size: 1.02rem;
			}
			.resources ul {
				margin: 0;
				padding-left: 1.05rem;
				display: grid;
				gap: 0.45rem;
			}
			.resources a {
				color: #3d5263;
			}
			@media (max-width: 720px) {
				main {
					width: calc(100% - 1.2rem);
				}
				.prose {
					font-size: 17px;
				}
			}
		</style>
	</head>

	<body>
		<main>
			<article class="article-shell">
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<div class="title">
						<a class="pill" href={`/${columnMeta.slug}`}>{columnMeta.name}</a>
						<h1>{title}</h1>
						<div class="date">
							发表于 <FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										最后更新于 <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
					</div>
					<PostStats postId={postId} />
					<slot />
					{resources && resources.length > 0 && (
						<section class="resources">
							<h3>延伸阅读 / 相关链接</h3>
							<ul>
								{resources.map((item) => (
									<li>
										<a href={item.url} target="_blank" rel="noreferrer">{item.title}</a>
										{item.note && <span> · {item.note}</span>}
									</li>
								))}
							</ul>
						</section>
					)}
					<EngagementPanel postId={postId} />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
