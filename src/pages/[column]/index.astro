---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import SiteSidebar from '../../components/SiteSidebar.astro';
import { COLUMNS, type ColumnMeta } from '../../lib/columns';
import { buildPostRouteMap, buildTagItems, sortPostsByViews } from '../../lib/content-helpers';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const sorted = await sortPostsByViews(posts);

	return COLUMNS.map((column) => ({
		params: { column: column.slug },
		props: {
			column,
			posts: sorted.filter((post) => post.data.column === column.slug),
			allPosts: posts,
		},
	}));
}

type Props = {
	column: ColumnMeta;
	posts: CollectionEntry<'blog'>[];
	allPosts: CollectionEntry<'blog'>[];
};

const { column, posts, allPosts } = Astro.props;
const pageTitle = `${column.name} - 薯条菌`;
const featuredPost = posts[0];
const compactPosts = posts.slice(1, 6);
const routeMap = buildPostRouteMap(allPosts);
const tags = buildTagItems(allPosts);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={column.summary} />
		<style>
			main {
				width: min(1120px, calc(100% - 2rem));
				max-width: none;
				padding: 1.4rem 0 2.8rem;
			}
			.content-layout {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 300px;
				gap: 1.4rem;
			}
			.return-link {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				font-size: 0.88rem;
				letter-spacing: 0.03em;
				text-decoration: none;
				color: #425564;
				border: 1px solid #d8e0e6;
				padding: 0.35rem 0.65rem;
				background: #ffffff;
				margin-bottom: 0.85rem;
			}
			.return-link:hover {
				border-color: #a8b4be;
				color: #1f2a33;
			}
			.column-hero {
				padding: 0.95rem 1rem;
				border: 1px solid #e3e7eb;
				background: #ffffff;
				margin-bottom: 0.9rem;
			}
			.column-hero h1 {
				margin: 0;
				font-size: clamp(1.7rem, 4vw, 2.2rem);
				font-family: var(--font-heading);
				color: #2d3d49;
			}
			.column-hero p {
				margin: 0.5rem 0 0;
				font-size: 0.9rem;
				line-height: 1.7;
				color: #5c6c79;
			}
			.featured-post {
				border: 1px solid #e3e7eb;
				background: #ffffff;
				padding: 0.7rem;
			}
			.featured-post a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.featured-post img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 0;
			}
			.featured-post h2 {
				margin: 0.35rem 0 0.35rem;
				font-size: 1.45rem;
				line-height: 1.45;
				color: #30414d;
			}
			.featured-post p {
				margin: 0;
				font-size: 0.9rem;
				color: #5f707d;
			}
			.meta {
				margin-top: 0.5rem;
				font-size: 0.76rem;
				letter-spacing: 0.06em;
				color: #7a8892;
			}
			.compact-list {
				margin-top: 0.95rem;
				display: grid;
				gap: 0.7rem;
			}
			.compact-item {
				border-top: 1px solid #e8ecef;
				padding-top: 0.7rem;
			}
			.compact-item a {
				display: grid;
				grid-template-columns: 102px minmax(0, 1fr);
				gap: 0.8rem;
				text-decoration: none;
				color: inherit;
			}
			.compact-item img {
				width: 102px;
				height: 102px;
				object-fit: cover;
				border-radius: 0;
			}
			.compact-item h2 {
				margin: 0.05rem 0 0.25rem;
				font-size: 1rem;
				line-height: 1.45;
				color: #33414d;
			}
			.compact-item p {
				margin: 0;
				font-size: 0.86rem;
				line-height: 1.6;
				color: #61717d;
			}
			@media (max-width: 980px) {
				.content-layout {
					grid-template-columns: 1fr;
				}
			}
			@media (max-width: 720px) {
				main {
					width: calc(100% - 1.2rem);
				}
				.compact-item a {
					grid-template-columns: 86px minmax(0, 1fr);
				}
				.compact-item img {
					width: 86px;
					height: 86px;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<section class="content-layout">
				<div>
					<a class="return-link" href="/">← 返回首页</a>
					<section class="column-hero">
						<h1>{column.name}</h1>
						<p>{column.summary}</p>
						<p>{column.description}</p>
					</section>

					{featuredPost && (
						<article class="featured-post">
							<a href={`/${featuredPost.data.column}/${featuredPost.id}/`}>
								{featuredPost.data.heroImage && (
									<Image src={featuredPost.data.heroImage} width={880} height={460} alt={featuredPost.data.title} />
								)}
								<p class="meta">{featuredPost.data.pubDate.toISOString().slice(0, 10)}</p>
								<h2>{featuredPost.data.title}</h2>
								<p>{featuredPost.data.description}</p>
							</a>
						</article>
					)}

					<div class="compact-list">
						{compactPosts.map((post) => (
							<article class="compact-item">
								<a href={`/${post.data.column}/${post.id}/`}>
									{post.data.heroImage && (
										<Image src={post.data.heroImage} width={160} height={160} alt={post.data.title} />
									)}
									<div>
										<p class="meta">{post.data.pubDate.toISOString().slice(0, 10)}</p>
										<h2>{post.data.title}</h2>
										<p>{post.data.description}</p>
									</div>
								</a>
							</article>
						))}
					</div>
				</div>

				<SiteSidebar tags={tags} routeMap={routeMap} />
			</section>
		</main>
		<Footer />
	</body>
</html>
