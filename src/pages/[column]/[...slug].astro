---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { COLUMN_KEYS } from '../../lib/columns';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { column: post.data.column, slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;

if (!COLUMN_KEYS.includes(post.data.column)) {
	throw new Error(`Invalid column value: ${post.data.column}`);
}

const { Content } = await render(post);
---

<BlogPost postId={post.id} {...post.data}>
	<Content />
</BlogPost>
