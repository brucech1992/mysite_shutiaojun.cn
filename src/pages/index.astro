---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const featuredProjects = [
	{ title: '内容系统升级', desc: '把零散想法整理成可持续发布的内容系统。', tag: 'Content / Workflow', href: '/projects' },
	{ title: '网站重构冲刺', desc: '在高压时间窗内完成上线、修复与稳定。', tag: 'Frontend / Delivery', href: '/projects' },
	{ title: 'AI 协同实验', desc: '多 agent 协作下的任务拆解与质量控制。', tag: 'AI Ops / PM', href: '/projects' },
];
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<div class="hero-left">
					<p class="kicker">个人站 · 持续更新</p>
					<h1>朋友你好，来根薯条~</h1>
					<p class="lead">我把做项目、写内容、踩坑复盘的过程，完整放在这里。希望你能少走弯路，也更快开始。</p>
					<div class="hero-actions">
						<a class="btn btn-primary" href="/projects">先看项目</a>
						<a class="btn btn-secondary" href="/blog">读最新文章</a>
					</div>
				</div>
				<aside class="hero-right">
					<p class="kicker">从这里开始</p>
					<ul>
						<li><a href="/about">了解我在做什么</a></li>
						<li><a href="/projects">看一个真实项目复盘</a></li>
						<li><a href="/blog">读一篇方法论文章</a></li>
						<li><a href="/#contact">直接联系我</a></li>
					</ul>
				</aside>
			</section>

			<section class="section">
				<div class="section-head"><p class="kicker">Featured Work</p><h2>近期代表项目</h2></div>
				<div class="cards">
					{featuredProjects.map((item) => (
						<article class="card">
							<p class="meta">From the case study</p>
							<h3>{item.title}</h3>
							<p>{item.desc}</p>
							<p class="tag">{item.tag}</p>
							<a href={item.href}>Read Case Study →</a>
						</article>
					))}
				</div>
			</section>

			<section class="section split" id="contact">
				<div>
					<p class="kicker">Blog</p>
					<h2>写给同路人的笔记</h2>
					<p>聚焦实操：模板、清单、流程、复盘。不是鸡汤，尽量都能直接用。</p>
					<a class="btn btn-secondary" href="/blog">去读文章</a>
				</div>
				<div class="contact-box">
					<p class="kicker">Contact</p>
					<h3>有想法，欢迎来聊</h3>
					<p>项目合作、内容交流、卡点求助，都可以直接发我。</p>
					<a class="btn btn-primary" href="mailto:hello@shutiaojun.cn">发送一条消息</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.home { width: min(1240px, calc(100% - 3rem)); margin: 0 auto; padding: 2rem 0 4rem; }
	.kicker { margin: 0 0 .6rem; font-size: .82rem; text-transform: uppercase; letter-spacing: .08em; color: #667085; }
	.hero,.section { border: 1px solid #e6e8ee; border-radius: 20px; background: #fff; }
	.hero { display: grid; grid-template-columns: 1.4fr 1fr; gap: 1.5rem; padding: 2rem; margin-bottom: 1rem; }
	h1 { font-size: clamp(2rem, 5vw, 3.4rem); line-height: 1.08; max-width: 13ch; margin: 0 0 1rem; }
	.lead { font-size: 1.07rem; color: #475467; max-width: 58ch; }
	.hero-right { background: #f8f9fc; border: 1px solid #eceff5; border-radius: 16px; padding: 1rem 1.1rem; }
	.hero-right ul { list-style: none; margin: 0; padding: 0; display: grid; gap: .55rem; }
	.hero-right a { color: #1f2937; text-decoration: none; border-bottom: 1px dashed #d0d5dd; padding-bottom: .25rem; }
	.hero-actions { display: flex; gap: .75rem; margin-top: 1.1rem; flex-wrap: wrap; }
	.section { padding: 1.6rem; margin-top: 1rem; }
	.section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: .8rem; }
	h2 { margin: 0; font-size: clamp(1.4rem, 3vw, 2rem); }
	.cards { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: .9rem; }
	.card { border: 1px solid #e8ebf2; border-radius: 16px; padding: 1rem; background: #fcfcfd; }
	.card .meta { color: #667085; font-size: .82rem; margin-bottom: .5rem; }
	.card h3 { margin: 0 0 .5rem; font-size: 1.18rem; }
	.card p { margin: 0 0 .6rem; color: #475467; }
	.card .tag { font-size: .9rem; color: #667085; }
	.card a { color: #111827; text-decoration: none; font-weight: 600; }
	.split { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: stretch; }
	.contact-box { border: 1px solid #eceff5; border-radius: 14px; padding: 1rem; background: #f8f9fc; }
	.btn { display: inline-flex; align-items: center; justify-content: center; height: 44px; padding: 0 18px; border-radius: 999px; font-size: .95rem; font-weight: 600; text-decoration: none; border: 1px solid transparent; }
	.btn-primary { background: #111827; color: #fff; }
	.btn-secondary { background: #fff; border-color: #d0d5dd; color: #111827; }
	@media (max-width: 980px) {
		.hero,.split,.cards { grid-template-columns: 1fr; }
	}
	@media (max-width: 640px) {
		.home { width: calc(100% - 1.2rem); }
		.hero,.section { padding: 1rem; border-radius: 14px; }
	}
</style>
