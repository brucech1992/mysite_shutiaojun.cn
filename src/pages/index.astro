---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const featured = [
	{
		title: '内容系统升级',
		summary: '把零散想法整理成可持续发布的内容系统，并建立从选题到发布的完整流程。',
		href: '/projects',
	},
	{
		title: '网站重构冲刺',
		summary: '在高压时间窗内完成上线、修复与稳定，确保访问链路和内容结构都可维护。',
		href: '/projects',
	},
	{
		title: 'AI 协同实验',
		summary: '用多 agent 协作拆解任务，验证“管理+执行+巡检”的交付效率。',
		href: '/projects',
	},
];

const allWork = [
	'内容系统升级',
	'网站重构冲刺',
	'AI 协同实验',
	'品牌叙事框架',
	'项目复盘模板',
	'个人知识库整理',
	'发布流程自动化',
	'设计规范沉淀',
];
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head>
	<body>
		<Header />
		<main class="home">
			<section class="hero panel">
				<div class="hero-main">
					<h1>朋友你好，来根薯条~</h1>
					<p class="hero-lead">我会持续分享项目、思考和实践过程。尽量讲清楚，也尽量讲实在。</p>
					<div class="hero-meta">
						<span>个人创作者</span>
						<span>内容实践者</span>
					</div>
				</div>
				<aside class="hero-nav panel-soft">
					<p class="kicker">Where you can start</p>
					<ul>
						<li><a href="/about">了解我的经历与方向</a></li>
						<li><a href="/projects">读一个项目案例</a></li>
						<li><a href="/blog">看最近一篇文章</a></li>
						<li><a href="/#contact">直接联系我</a></li>
					</ul>
				</aside>
			</section>

			<section class="featured panel">
				<div class="section-head">
					<p class="kicker">Featured Work</p>
					<h2>精选项目</h2>
				</div>
				<div class="featured-list">
					{featured.map((item) => (
						<article class="feature-item">
							<div class="feature-copy">
								<p class="meta">From the case study</p>
								<h3>{item.title}</h3>
								<p>{item.summary}</p>
								<a href={item.href}>Read Case Study →</a>
							</div>
							<div class="feature-visual" aria-hidden="true"></div>
						</article>
					))}
				</div>
			</section>

			<section class="allwork panel">
				<div class="section-head line">
					<h2>All work</h2>
					<span>{allWork.length}</span>
				</div>
				<div class="work-grid">
					{allWork.map((name, i) => (
						<a href="/projects" class="work-card">
							<span class="index">{String(i + 1).padStart(2, '0')}</span>
							<h3>{name}</h3>
							<p>Creative Direction · Web Design · Delivery</p>
						</a>
					))}
				</div>
			</section>

			<section class="blog panel" id="contact">
				<div class="section-head">
					<h2>Blog</h2>
					<a href="/blog">查看全部</a>
				</div>
				<article class="blog-card">
					<h3>我是怎么把一个站点从 404 拉回可用状态的</h3>
					<p class="date">Mar 5, 2026</p>
					<p>从发布链路排查、工作流收敛到线上验证，这篇会把全过程写清楚，给你一份可复用的排障手册。</p>
					<a href="/blog">Keep Reading →</a>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: linear-gradient(180deg, #e8f2fb 0%, #f8f5e8 60%, #f7f8fa 100%);
		color: #1f2937;
		font-size: 18px;
	}
	.home {
		width: min(1320px, calc(100% - 2.4rem));
		margin: 0 auto;
		padding: 2.1rem 0 4.2rem;
		display: grid;
		gap: 1.25rem;
	}
	.panel {
		background: rgba(255, 255, 255, 0.88);
		backdrop-filter: blur(2px);
		border: 1px solid #d8e5ef;
		border-radius: 24px;
		padding: 1.8rem;
		box-shadow: 0 12px 28px rgba(148, 163, 184, 0.13);
	}
	.panel + .panel { margin-top: 0; }
	.panel-soft {
		background: linear-gradient(180deg, #f5f9fd 0%, #faf6e7 100%);
		border: 1px solid #dce6ea;
		border-radius: 18px;
		padding: 1.15rem;
	}
	.kicker { margin: 0 0 .45rem; color: #617287; text-transform: uppercase; letter-spacing: .08em; font-size: .76rem; }
	h1 { margin: 0 0 1rem; font-size: clamp(2.55rem, 6vw, 4.8rem); line-height: .96; max-width: 10ch; letter-spacing: -0.02em; }
	h2 { margin: 0; font-size: clamp(1.6rem, 3.1vw, 2.4rem); letter-spacing: -0.01em; }
	h3 { margin: 0 0 .55rem; font-size: clamp(1.16rem, 2vw, 1.58rem); }
	p { margin: 0 0 .75rem; color: #526072; }
	a { color: #1f2937; text-decoration: none; }
	a:hover { text-decoration: underline; }
	.hero { display: grid; grid-template-columns: 1.5fr 1fr; gap: 1.4rem; align-items: stretch; }
	.hero-main { display: grid; align-content: start; gap: .75rem; }
	.hero-lead { max-width: 62ch; font-size: 1.03rem; }
	.hero-meta { display: flex; gap: .8rem; flex-wrap: wrap; margin-top: .45rem; }
	.hero-meta span { border: 1px solid #cfddea; background: #edf4fb; border-radius: 999px; padding: .38rem .74rem; font-size: .84rem; color: #5e7189; }
	.hero-nav ul { margin: 0; padding-left: 1rem; display: grid; gap: .56rem; }
	.section-head { display: flex; justify-content: space-between; align-items: center; gap: .8rem; margin-bottom: 1.1rem; }
	.section-head.line { padding-bottom: .78rem; border-bottom: 1px solid #d9e5ec; }
	.featured-list { display: grid; gap: .95rem; }
	.feature-item { display: grid; grid-template-columns: 1fr .95fr; gap: 1rem; border: 1px solid #dbe6ee; border-radius: 16px; padding: 1.05rem; background: #f8fbfd; }
	.meta { font-size: .78rem; color: #6e7f91; text-transform: uppercase; letter-spacing: .06em; }
	.feature-visual { border-radius: 12px; min-height: 180px; background: linear-gradient(140deg, #dcebfa 0%, #e9f2fb 34%, #f7efcb 100%); border: 1px solid #d7e4ec; }
	.work-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: .86rem; }
	.work-card { display: block; border: 1px solid #dce6ec; border-radius: 14px; padding: .95rem; background: #fbfdff; }
	.work-card .index { font-size: .75rem; color: #6b7c90; display: inline-block; margin-bottom: .4rem; }
	.work-card p { margin: 0; font-size: .86rem; color: #66778a; }
	.blog-card { border: 1px solid #dbe6ed; border-radius: 16px; padding: 1.08rem; background: #f8fbfc; }
	.blog-card .date { font-size: .85rem; color: #6b7a8b; }
	@media (max-width: 1080px) {
		.hero, .feature-item { grid-template-columns: 1fr; }
		.work-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
	}
	@media (max-width: 640px) {
		.home { width: calc(100% - 1rem); padding-top: 1.1rem; }
		.panel { padding: 1rem; border-radius: 14px; }
		h1 { font-size: clamp(2rem, 10vw, 3rem); }
		.work-grid { grid-template-columns: 1fr; }
	}
</style>
