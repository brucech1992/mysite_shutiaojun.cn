---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import AboutImage from '../assets/blog-placeholder-about.jpg';
import CoverOne from '../assets/blog-placeholder-1.jpg';
import CoverTwo from '../assets/blog-placeholder-2.jpg';
import CoverThree from '../assets/blog-placeholder-3.jpg';
import CoverFour from '../assets/blog-placeholder-4.jpg';
import CoverFive from '../assets/blog-placeholder-5.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const categories = [
	{
		label: '设计思考',
		href: '/blog',
	},
	{
		label: '项目复盘',
		href: '/projects',
	},
	{
		label: '生活随记',
		href: '/notes',
	},
	{
		label: '关于我',
		href: '/about',
	},
];

const posts = [
	{
		title: '把一个复杂项目拆成可执行的 5 个动作',
		summary: '从目标、节奏到交付标准，这篇记录我如何把“想做”变成“能持续做”。',
		date: '2026-03-05',
		category: '项目复盘',
		href: '/projects',
		image: CoverOne,
	},
	{
		title: '网站改版这次我学到的三个关键判断',
		summary: '不是追求更花哨，而是让信息更清楚、更新更轻松、上线更稳定。',
		date: '2026-03-04',
		category: '设计思考',
		href: '/blog',
		image: CoverTwo,
	},
	{
		title: 'AI 协作写站点：流程比工具更重要',
		summary: '我把任务拆成内容、设计、前端、巡检四层，交付速度明显提升。',
		date: '2026-03-03',
		category: '实践记录',
		href: '/blog',
		image: CoverThree,
	},
	{
		title: '把日常笔记变成可复用的知识资产',
		summary: '笔记不是存档，而是下一次行动的脚手架。',
		date: '2026-03-02',
		category: '生活随记',
		href: '/notes',
		image: CoverFour,
	},
	{
		title: '为什么我决定把“做事过程”公开出来',
		summary: '公开不是表演，是为了建立反馈回路，也让自己更诚实地迭代。',
		date: '2026-03-01',
		category: '关于我',
		href: '/about',
		image: CoverFive,
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head>
	<body>
		<main class="home-shell">
			<header class="page-branding">
				<p class="brand-kicker">Shutiaojun Journal</p>
				<h1>薯条君</h1>
				<p class="brand-desc">记录设计思考、项目复盘与生活灵感。</p>
				<nav class="topic-nav" aria-label="主页分类导航">
					{categories.map((item) => (
						<a href={item.href}>{item.label}</a>
					))}
				</nav>
			</header>

			<section class="content-layout">
				<div class="post-stream">
					{posts.map((post, index) => (
						<article class="post-card" style={`animation-delay:${index * 80}ms`}>
							<a class="post-link" href={post.href}>
								<div class="post-thumb">
									<Image src={post.image} width={880} height={478} alt={post.title} />
								</div>
								<div class="post-copy">
									<p class="post-meta">{post.category} · {post.date}</p>
									<h2>{post.title}</h2>
									<p>{post.summary}</p>
									<span class="read-more">阅读全文</span>
								</div>
							</a>
						</article>
					))}
				</div>

				<aside class="sidebar" id="contact">
					<section class="widget profile-widget">
						<Image src={AboutImage} width={320} height={220} alt="薯条君头像" />
						<h3>关于我</h3>
						<p>
							我是薯条君，正在持续记录做事的方法、项目过程和真实生活。
							欢迎你来这里一起交流。
						</p>
						<a href="/about">了解更多</a>
					</section>

					<section class="widget">
						<h3>快速入口</h3>
						<ul>
							<li><a href="/projects">项目案例</a></li>
							<li><a href="/blog">最新文章</a></li>
							<li><a href="/notes">生活笔记</a></li>
							<li><a href="/about">个人介绍</a></li>
						</ul>
					</section>

					<section class="widget">
						<h3>联系我</h3>
						<p>合作、交流或提问都可以直接发邮件。</p>
						<a class="contact-btn" href="mailto:hello@shutiaojun.cn">hello@shutiaojun.cn</a>
					</section>
				</aside>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: #ffffff;
		color: #161616;
		font-size: 17px;
		line-height: 1.8;
	}
	:global(main) {
		width: auto;
		max-width: none;
		padding: 0;
	}
	.home-shell {
		width: min(1080px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 0 0 4rem;
	}
	.page-branding {
		padding: 2.9rem 0 0;
		text-align: center;
		border-bottom: 1px solid #ececec;
	}
	.brand-kicker {
		margin: 0;
		color: #8b8b8b;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		font-size: 0.72rem;
	}
	h1 {
		margin: 0.35rem 0 0.22rem;
		font-size: clamp(2.5rem, 6vw, 3.5rem);
		font-weight: 500;
		letter-spacing: 0.08em;
		line-height: 1.15;
	}
	.brand-desc {
		margin: 0;
		color: #666666;
		font-size: 0.95rem;
	}
	.topic-nav {
		margin-top: 1.6rem;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1.5rem;
		padding: 0.95rem 0;
		border-top: 1px solid #f0f0f0;
	}
	.topic-nav a {
		font-size: 0.92rem;
		color: #444444;
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.topic-nav a:hover {
		color: #000000;
	}
	.content-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 290px;
		gap: 2.2rem;
		padding-top: 2.15rem;
	}
	h2 {
		margin: 0.6rem 0 0.5rem;
		font-size: clamp(1.28rem, 2.5vw, 1.72rem);
		line-height: 1.4;
		letter-spacing: 0.01em;
		font-weight: 500;
	}
	h3 {
		margin: 0 0 0.6rem;
		font-size: 1.06rem;
		font-weight: 600;
	}
	p {
		margin: 0;
		color: #5c5c5c;
	}
	.post-stream {
		min-width: 0;
	}
	.post-card {
		padding-bottom: 2.1rem;
		margin-bottom: 2.1rem;
		border-bottom: 1px solid #efefef;
		opacity: 0;
		transform: translateY(10px);
		animation: fade-up 0.55s ease forwards;
	}
	.post-link {
		display: block;
		text-decoration: none;
	}
	.post-thumb {
		overflow: hidden;
		border-radius: 4px;
		background: #f5f5f5;
		margin-bottom: 1rem;
	}
	.post-thumb img {
		display: block;
		width: 100%;
		height: auto;
		transition: transform 0.4s ease;
	}
	.post-link:hover .post-thumb img {
		transform: scale(1.02);
	}
	.post-meta {
		color: #808080;
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.post-copy p {
		margin-bottom: 0.8rem;
	}
	.read-more {
		display: inline-block;
		color: #222222;
		font-size: 0.86rem;
		border-bottom: 1px solid #cfcfcf;
		padding-bottom: 0.05rem;
	}
	.sidebar {
		display: grid;
		gap: 1rem;
		align-content: start;
	}
	.widget {
		border: 1px solid #ececec;
		padding: 1rem;
		background: #ffffff;
	}
	.widget ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.5rem;
	}
	.widget a {
		color: #5b6773;
		text-decoration: none;
		font-size: 0.92rem;
	}
	.widget a:hover {
		color: #151515;
	}
	.profile-widget img {
		display: block;
		margin-bottom: 0.7rem;
		border-radius: 0;
	}
	.profile-widget p {
		margin-bottom: 0.55rem;
		font-size: 0.92rem;
	}
	.contact-btn {
		display: inline-block;
		margin-top: 0.5rem;
		padding-bottom: 0.15rem;
		border-bottom: 1px solid #cfcfcf;
	}
	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@media (max-width: 980px) {
		.content-layout {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
		.sidebar {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			align-items: start;
		}
	}
	@media (max-width: 720px) {
		.home-shell {
			width: calc(100% - 1.2rem);
		}
		.topic-nav {
			gap: 0.85rem 1.1rem;
			padding: 0.8rem 0;
		}
		h1 {
			letter-spacing: 0.02em;
		}
		.sidebar {
			grid-template-columns: 1fr;
		}
	}
</style>
