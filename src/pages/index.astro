---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const featured = [
	{
		title: '内容系统升级',
		summary: '把零散想法整理成可持续发布的内容系统，并建立从选题到发布的完整流程。',
		href: '/projects',
	},
	{
		title: '网站重构冲刺',
		summary: '在高压时间窗内完成上线、修复与稳定，确保访问链路和内容结构都可维护。',
		href: '/projects',
	},
	{
		title: 'AI 协同实验',
		summary: '用多 agent 协作拆解任务，验证“管理+执行+巡检”的交付效率。',
		href: '/projects',
	},
];

const allWork = [
	'内容系统升级',
	'网站重构冲刺',
	'AI 协同实验',
	'品牌叙事框架',
	'项目复盘模板',
	'个人知识库整理',
	'发布流程自动化',
	'设计规范沉淀',
];
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head>
	<body>
		<Header />
		<main class="home">
			<section class="hero panel">
				<div class="hero-main">
					<h1>朋友你好，来根薯条~</h1>
					<p class="hero-lead">我会持续分享项目、思考和实践过程。尽量讲清楚，也尽量讲实在。</p>
					<div class="hero-meta">
						<span>个人创作者</span>
						<span>内容实践者</span>
					</div>
				</div>
				<aside class="hero-nav panel-soft">
					<p class="kicker">Where you can start</p>
					<ul>
						<li><a href="/about">了解我的经历与方向</a></li>
						<li><a href="/projects">读一个项目案例</a></li>
						<li><a href="/blog">看最近一篇文章</a></li>
						<li><a href="/#contact">直接联系我</a></li>
					</ul>
				</aside>
			</section>

			<section class="featured panel">
				<div class="section-head">
					<p class="kicker">Featured Work</p>
					<h2>精选项目</h2>
				</div>
				<div class="featured-list">
					{featured.map((item) => (
						<article class="feature-item">
							<div class="feature-copy">
								<p class="meta">From the case study</p>
								<h3>{item.title}</h3>
								<p>{item.summary}</p>
								<a href={item.href}>Read Case Study →</a>
							</div>
							<div class="feature-visual" aria-hidden="true"></div>
						</article>
					))}
				</div>
			</section>

			<section class="allwork panel">
				<div class="section-head line">
					<h2>All work</h2>
					<span>{allWork.length}</span>
				</div>
				<div class="work-grid">
					{allWork.map((name, i) => (
						<a href="/projects" class="work-card">
							<span class="index">{String(i + 1).padStart(2, '0')}</span>
							<h3>{name}</h3>
							<p>Creative Direction · Web Design · Delivery</p>
						</a>
					))}
				</div>
			</section>

			<section class="blog panel" id="contact">
				<div class="section-head">
					<h2>Blog</h2>
					<a href="/blog">查看全部</a>
				</div>
				<article class="blog-card">
					<h3>我是怎么把一个站点从 404 拉回可用状态的</h3>
					<p class="date">Mar 5, 2026</p>
					<p>从发布链路排查、工作流收敛到线上验证，这篇会把全过程写清楚，给你一份可复用的排障手册。</p>
					<a href="/blog">Keep Reading →</a>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: #f3f4f6;
		color: #111827;
		font-size: 18px;
	}
	.home { width: min(1320px, calc(100% - 2rem)); margin: 0 auto; padding: 1.2rem 0 3.5rem; }
	.panel { background: #fff; border: 1px solid #e5e7eb; border-radius: 18px; padding: 1.4rem; }
	.panel + .panel { margin-top: .9rem; }
	.panel-soft { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 14px; padding: 1rem; }
	.kicker { margin: 0 0 .45rem; color: #6b7280; text-transform: uppercase; letter-spacing: .08em; font-size: .78rem; }
	h1 { margin: 0 0 .8rem; font-size: clamp(2.4rem, 5.8vw, 4.4rem); line-height: .98; max-width: 10ch; }
	h2 { margin: 0; font-size: clamp(1.5rem, 3vw, 2.2rem); }
	h3 { margin: 0 0 .55rem; font-size: clamp(1.15rem, 2vw, 1.55rem); }
	p { margin: 0 0 .75rem; color: #4b5563; }
	a { color: #111827; text-decoration: none; }
	a:hover { text-decoration: underline; }
	.hero { display: grid; grid-template-columns: 1.35fr 1fr; gap: 1rem; align-items: stretch; }
	.hero-lead { max-width: 60ch; }
	.hero-meta { display: flex; gap: .7rem; flex-wrap: wrap; }
	.hero-meta span { border: 1px solid #d1d5db; border-radius: 999px; padding: .35rem .7rem; font-size: .85rem; color: #6b7280; }
	.hero-nav ul { margin: 0; padding-left: 1rem; display: grid; gap: .45rem; }
	.section-head { display: flex; justify-content: space-between; align-items: center; gap: .8rem; margin-bottom: .9rem; }
	.section-head.line { padding-bottom: .65rem; border-bottom: 1px solid #e5e7eb; }
	.featured-list { display: grid; gap: .7rem; }
	.feature-item { display: grid; grid-template-columns: 1fr .9fr; gap: .9rem; border: 1px solid #e5e7eb; border-radius: 14px; padding: .95rem; background: #fafafa; }
	.meta { font-size: .78rem; color: #6b7280; text-transform: uppercase; letter-spacing: .06em; }
	.feature-visual { border-radius: 12px; min-height: 160px; background: linear-gradient(135deg, #e5e7eb 0%, #f9fafb 50%, #dbeafe 100%); border: 1px solid #e5e7eb; }
	.work-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: .7rem; }
	.work-card { display: block; border: 1px solid #e5e7eb; border-radius: 12px; padding: .85rem; background: #fcfcfd; }
	.work-card .index { font-size: .75rem; color: #6b7280; display: inline-block; margin-bottom: .35rem; }
	.work-card p { margin: 0; font-size: .86rem; color: #6b7280; }
	.blog-card { border: 1px solid #e5e7eb; border-radius: 14px; padding: 1rem; background: #fafafa; }
	.blog-card .date { font-size: .85rem; color: #6b7280; }
	@media (max-width: 1080px) {
		.hero, .feature-item { grid-template-columns: 1fr; }
		.work-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
	}
	@media (max-width: 640px) {
		.home { width: calc(100% - .8rem); }
		.panel { padding: .9rem; border-radius: 12px; }
		h1 { font-size: clamp(2rem, 10vw, 3rem); }
		.work-grid { grid-template-columns: 1fr; }
	}
</style>
