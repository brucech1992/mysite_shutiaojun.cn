---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import SiteSidebar from '../components/SiteSidebar.astro';
import HeroSeaside from '../assets/hero-seaside.png';
import { SITE_DESCRIPTION } from '../consts';
import { COLUMNS, getColumnMeta } from '../lib/columns';
import { buildPostRouteMap, buildTagItems, sortPostsByViews } from '../lib/content-helpers';

const HOME_TITLE = '朋友你好，来根薯条～';

const posts = await getCollection('blog');
const sortedPosts = await sortPostsByViews(posts);
const featuredPost = sortedPosts[0];
const compactPosts = sortedPosts.slice(1, 6);
const routeMap = buildPostRouteMap(posts);
const tags = buildTagItems(posts);
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={HOME_TITLE} description={SITE_DESCRIPTION} /></head>
	<body>
		<main class="home-shell">
			<header class="page-branding" style={`--hero-bg: url(${HeroSeaside.src})`}>
				<h1>整点儿薯条吧</h1>
				<p class="brand-desc">薯条菌的观察、思考与推荐，分成三种味道慢慢更新。</p>
				<nav class="topic-nav" aria-label="栏目导航">
					{COLUMNS.map((column) => (
						<a href={`/${column.slug}`}>{column.name}</a>
					))}
				</nav>
			</header>

			<section class="content-layout">
				<div class="main-feed">
					<h2>热门文章（按浏览量）</h2>
					{featuredPost && (
						<article class="featured-post">
							<a href={`/${featuredPost.data.column}/${featuredPost.id}/`}>
								{featuredPost.data.heroImage && (
									<Image src={featuredPost.data.heroImage} width={920} height={480} alt={featuredPost.data.title} />
								)}
								<p class="meta">{getColumnMeta(featuredPost.data.column).name} · {featuredPost.data.pubDate.toISOString().slice(0, 10)}</p>
								<h3>{featuredPost.data.title}</h3>
								<p>{featuredPost.data.description}</p>
							</a>
						</article>
					)}

					<div class="compact-list">
						{compactPosts.map((post) => (
							<article class="compact-item">
								<a href={`/${post.data.column}/${post.id}/`}>
									{post.data.heroImage && (
										<Image src={post.data.heroImage} width={160} height={160} alt={post.data.title} />
									)}
									<div class="copy">
										<p class="meta">{getColumnMeta(post.data.column).name} · {post.data.pubDate.toISOString().slice(0, 10)}</p>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
									</div>
								</a>
							</article>
						))}
					</div>
				</div>

				<SiteSidebar tags={tags} routeMap={routeMap} />
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: #f8f9fb;
		color: #3f4a54;
		font-size: 16px;
		line-height: 1.8;
	}
	:global(main) {
		max-width: none;
		width: auto;
		padding: 0;
	}
	.home-shell {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		padding-bottom: 3rem;
	}
	.page-branding {
		padding: 3rem 1.1rem 1.2rem;
		background: var(--hero-bg);
		background-size: cover;
		background-position: center;
		border: 1px solid #d8dee4;
		border-top: 0;
	}
	h1 {
		margin: 0;
		font-size: clamp(2.25rem, 4.4vw, 3.1rem);
		font-family: var(--font-display);
		font-weight: 400;
		color: #f7fbff;
		letter-spacing: 0.04em;
	}
	.brand-desc {
		margin: 0.5rem 0 0;
		font-size: 0.95rem;
		color: #f2f8fc;
	}
	.topic-nav {
		margin-top: 1.1rem;
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		padding-top: 0.8rem;
		border-top: 1px solid rgba(243, 249, 253, 0.7);
	}
	.topic-nav a {
		font-size: 0.88rem;
		letter-spacing: 0.03em;
		text-decoration: none;
		color: #eff7fc;
	}
	.topic-nav a:hover {
		color: #ffffff;
	}
	.content-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 300px;
		gap: 1.4rem;
		margin-top: 1.2rem;
	}
	.main-feed h2 {
		margin: 0 0 0.8rem;
		font-size: 1.05rem;
		letter-spacing: 0.03em;
		font-family: var(--font-heading);
		font-weight: 600;
		color: #36414b;
	}
	.featured-post {
		background: #ffffff;
		border: 1px solid #e3e7eb;
		padding: 0.7rem;
	}
	.featured-post a {
		text-decoration: none;
		color: inherit;
		display: block;
	}
	.featured-post img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0;
	}
	.featured-post h3 {
		margin: 0.35rem 0 0.4rem;
		font-size: clamp(1.25rem, 2.4vw, 1.55rem);
		line-height: 1.45;
		font-family: var(--font-heading);
		color: #2f3941;
	}
	.featured-post p {
		margin: 0;
		font-size: 0.93rem;
		color: #586774;
	}
	.meta {
		margin-top: 0.5rem;
		font-size: 0.76rem;
		letter-spacing: 0.06em;
		color: #7b8690;
		text-transform: capitalize;
	}
	.compact-list {
		margin-top: 0.95rem;
		display: grid;
		gap: 0.7rem;
	}
	.compact-item {
		border-top: 1px solid #e8ecef;
		padding-top: 0.7rem;
	}
	.compact-item a {
		display: grid;
		grid-template-columns: 102px minmax(0, 1fr);
		gap: 0.8rem;
		text-decoration: none;
		color: inherit;
	}
	.compact-item img {
		width: 102px;
		height: 102px;
		object-fit: cover;
		border-radius: 0;
	}
	.compact-item h3 {
		margin: 0.05rem 0 0.25rem;
		font-size: 1rem;
		line-height: 1.45;
		color: #33414d;
	}
	.compact-item p {
		margin: 0;
		font-size: 0.86rem;
		line-height: 1.6;
		color: #61717d;
	}
	@media (max-width: 980px) {
		.content-layout {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 720px) {
		.home-shell {
			width: calc(100% - 1.2rem);
		}
		.page-branding {
			background-position: left center;
		}
		.compact-item a {
			grid-template-columns: 86px minmax(0, 1fr);
		}
		.compact-item img {
			width: 86px;
			height: 86px;
		}
	}
</style>
